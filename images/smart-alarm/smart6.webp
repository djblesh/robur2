sManager.6NE0hugY.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/hooks-useUnauthenticatedErrorModal.DuSJSiRl.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/CaptureEvents-ButtonWithRegisterWebPixel.ChRj_lZQ.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/events-shared.xk3PqPtY.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/images-flag-icon.C_eXYJRt.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/images-payment-icon.D2Fpq5Mq.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/locale-en.Bh-E6-Un.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/page-OnePage.D2D4WM_H.js" crossorigin=""><style>.omg-tracking-result {
  padding: 1rem 3rem;
  box-shadow: var(
    --p-card-shadow,
    0 0 0 1px rgba(63, 63, 68, 0.05),
    0 1px 3px 0 rgba(63, 63, 68, 0.15)
  );
}

.omg-tracking-status {
  font-weight: 600;
}

.omg-tracking-link {
  color: #3366bb;
  cursor: pointer;
}

.omg-tracking-back {
  color: #3366bb;
  cursor: pointer;
  text-align: center;
  display: flex;
  gap: 5px;
  align-items: center;
  justify-content: center;
}

.omg-tracking-back svg {
  fill: #3366bb;
}
</style><style>.tab-container {
  display: grid;
  margin: auto;
  margin-top: 0.625rem;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: auto 1fr;
  width: 100%;
}
.omg-widget {
  /* border: 1px solid #ccc; */
  padding: 0.5rem 2rem;
  box-shadow: var(
    --p-card-shadow,
    0 0 0 1px rgba(63, 63, 68, 0.05),
    0 1px 3px 0 rgba(63, 63, 68, 0.15)
  );
}
/* TAB CONTROLS Hide radios */
.input-asset {
  display: none !important;
}
input:checked + .tracking-form-label {
  color: #000;
  /* border-bottom: solid 2px red !important; */
  transition: all 250ms;
}
.tracking-form-label {
  margin: auto;
  font-weight: 400;
  /* font-size: 1rem; */
  cursor: pointer;
  transition: color 250ms;
  padding: 1rem 1.875rem;
  text-align: center;
  transition: all 250ms;
  color: #000;
}
.omg-tracking-form-tab {
  border: 1 solid #ccc;
  margin: 0 auto;
  text-align: center;
}
.omg-form {
  padding: 0 2.5;
  /* font-size: 1rem; */
  display: flex;
  flex-direction: column;
  text-align: left;
  justify-content: center;
  gap: 1rem;
}
.omg-form p {
  /* font-size: 1rem; */
  font-weight: 400;
  line-height: 2rem;
  color: var(--color-text);
}
.omg-form .btn.btn-custom {
  height: 3.5rem;
  /* font-size: 1rem; */
  font-weight: 700;
  border-radius: 1rem;
  border: none;
  background-color: var(--button-track-color);
  color: var(--button-track-text-color);
  border-color: var(--button-track-color);
}
.omg-form .btn.btn-custom:hover,
.omg-form .btn.btn-custom:active,
.omg-form .btn.btn-custom:focus {
  background-color: var(--button-track-color);
  border-color: var(--button-track-color);
  color: var(--button-track-text-color);
}
.omg-form .omg-form-group input {
  width: 100%;
  /* border-radius: 15px; */
  height: 3.375rem;
  outline: none;
  /* font-size: 1rem; */
  padding: 0.875rem;
  /* border: none; */
}
.omg-form .omg-form-group:focus {
  outline: none;
}
.omg-form .omg-form-group label {
  margin-bottom: 0.5rem;
}
.omg-form .tracking-form-label:hover {
  color: var(--color-text);
}
tab-content {
  display: grid;
  grid-column: 1/-1;
  padding: 0 1.25rem;
}
input#tabToggle01:checked ~ tab-content:not(:nth-of-type(1)),
input#tabToggle02:checked ~ tab-content:not(:nth-of-type(2)),
input#tabToggle04:checked ~ tab-content:not(:nth-of-type(3)) {
  display: none;
}
.form-tracking {
  display: flex;
  justify-content: space-between;
  flex-wrap: nowrap;
  height: 33.75rem;
}
.form-tracking .img-fluid {
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
}

.form-tracking .omg-section {
  border-radius: 1.5rem;
  background-color: var(--progress-color);
  color: var(--color-text);
}
</style><style>/* html {
  font-size: 62.5%;
} */
.lds-ellipsis {
  display: inline-block;
  position: relative;
  width: 80px;
  height: 80px;
}
.lds-ellipsis div {
  position: absolute;
  top: 33px;
  width: 13px;
  height: 13px;
  border-radius: 50%;
  background: rgb(102, 21, 21);
  animation-timing-function: cubic-bezier(0, 1, 1, 0);
}
.lds-ellipsis div:nth-child(1) {
  left: 8px;
  animation: lds-ellipsis1 0.6s infinite;
}
.lds-ellipsis div:nth-child(2) {
  left: 8px;
  animation: lds-ellipsis2 0.6s infinite;
}
.lds-ellipsis div:nth-child(3) {
  left: 32px;
  animation: lds-ellipsis2 0.6s infinite;
}
.lds-ellipsis div:nth-child(4) {
  left: 56px;
  animation: lds-ellipsis3 0.6s infinite;
}
@keyframes lds-ellipsis1 {
  0% {
    transform: scale(0);
  }
  100% {
    transform: scale(1);
  }
}
@keyframes lds-ellipsis3 {
  0% {
    transform: scale(1);
  }
  100% {
    transform: scale(0);
  }
}
@keyframes lds-ellipsis2 {
  0% {
    transform: translate(0, 0);
  }
  100% {
    transform: translate(24px, 0);
  }
}

/* App */
.omega-order-lookup {
  margin: 2rem;
}

.omg-widget-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
</style><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/MarketsProDisclaimer.hjyyrOON.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/CrossBorderConsolidation.DFgZJly6.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/hooks-useSubscribeMessenger.0HH2NQjb.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/hooks-useSuppressShopPayModalOnLoad.B6pdNT18.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/hooks-useHasOrdersFromMultipleShops.SDngVQMv.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/ShopPayLogo.CSfh6_C6.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/VaultedPayment.DPEMXEmk.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/ShippingGroupsSummaryLine.-giovg9s.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/StackedMerchandisePreview.GZMeDmNc.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/PickupPointCarrierLogo.BUKn6Mes.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="https://www.x-sense.com/cdn/shopifycloud/checkout-web/assets/c1/AutocompleteField-hooks.rUsL7EvV.js" crossorigin=""><link rel="prefetch" fetchpriority="low" as="script" href="