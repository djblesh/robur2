  <div id="shopify-block-AUGFGMlU1N3JlUExDV__product-left-image-modal" class="shopify-block">


<template x-teleport="body" data-teleport-template="true"></template>
<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('productImageModal', () => ({
      swiper3: null,
      swiper4: null,
      index: 0,
      initSwiper() {
        // 先初始化底部缩略图，再与主轮播通过 thumbs 关联（点击缩略图会切换主图，并带 swiper-slide-thumb-active）
        this.swiper4 = new Swiper(this.$refs.swiper4, {
          slidesPerView: 'auto',
          spaceBetween: 4,
          loop: false,
          freeMode: true,
          watchSlidesProgress: true,
          centeredSlides: false,
        });
        this.swiper3 = new Swiper(this.$refs.swiper3, {
          slidesPerView: 1,
          loop: false,
          effect: 'slide',
          thumbs: {
            swiper: this.swiper4,
          },
          on: {
            slideChange: (swiper) => {
              this.isFirstSlide = swiper.isBeginning;
              this.isLastSlide = swiper.isEnd;
              this.index = swiper.activeIndex;
              if (this.swiper4) {
                this.swiper4.slideTo(this.swiper3.activeIndex);
              }
            },
          },
        });
        this.index = this.swiper3 ? this.swiper3.activeIndex : 0;
      },
      open() {
        this.isOpenImageModal = true;
      },
      // 关闭
      close() {
        this.isOpenImageModal = false;
      },
      // 切换
      toggle() {
        this.isOpenImageModal = !this.isOpenImageModal;
      },
    }));
  });
</script>

</div>

</div>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('productLeft', () => ({
      isFirstSlide: true,
      isLastSlide: false,
      isOpenImageModal: false,
      tabs: 0,
      index: 0,
      indexVideo: 0,
      initSwiper() {
        // 先初始化缩略图轮播
        this.swiper2 = new Swiper(this.$refs.swiper2, {
          slidesPerView: 'auto',
          spaceBetween: 16,
          loop: false,
          freeMode: true,
          watchSlidesProgress: true,
          centeredSlides: false,
        });
        // 再初始化主轮播并连接缩略图
        this.swiper1 = new Swiper(this.$refs.swiper1, {
          slidesPerView: 1,
          loop: false,
          effect: 'slide',
          thumbs: {
            swiper: this.swiper2,
          },
          on: {
            slideChange: (swiper) => {
              this.isFirstSlide = swiper.isBeginning;
              this.isLastSlide = swiper.isEnd;
              this.index = swiper.activeIndex;
              if (this.swiper2) {
                this.swiper2.slideTo(this.swiper1.activeIndex);
              }
            },
          },
        });
        this.handleSelectImage(0);
      },
    }));
  });
</script>

</div>

