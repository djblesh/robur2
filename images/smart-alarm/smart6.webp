<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('footerNav', () => ({
      open: false,
      toggleOpen() {
        this.open = !this.open;
      },
    }));
  });
  document.addEventListener('alpine:init', () => {
    Alpine.directive('collapse', (el, { expression }, { evaluateLater, effect }) => {
      const isOpen = evaluateLater(expression);
      const DURATION_MS = 300;

      let initial = true;
      let onTransitionEnd = null;

      const clearPending = () => {
        if (onTransitionEnd) {
          el.removeEventListener('transitionend', onTransitionEnd);
          onTransitionEnd = null;
        }
      };

      effect(() => {
        isOpen((value) => {
          if (initial) {
            el.style.height = value ? 'auto' : '0px';
            initial = false;
            return;
          }

          clearPending();

          if (value) {
            el.style.height = 'auto';
            const h = el.offsetHeight;
            el.style.height = '0px';
            el.offsetHeight;
            el.style.transition = `height ${DURATION_MS}ms ease`;
            el.style.height = `${h}px`;

            onTransitionEnd = (e) => {
              if (e.propertyName !== 'height' || e.target !== el) return;
              el.style.height = 'auto';
              clearPending();
            };
            el.addEventListener('transitionend', onTransitionEnd);
          } else {
            const h = el.offsetHeight;
            el.style.height = `${h}px`;
            el.offsetHeight;
            el.style.transition = `height ${DURATION_MS}ms ease`;
            el.style.height = '0px';
          }
        });
      });
    });
  });
</script>

