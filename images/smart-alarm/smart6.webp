</div><div id="shopify-section-sections--20433618141424__main-ip" class="shopify-section shopify-section-group-cart-group z-9990 sticky top-0 left-0"><div x-data="ipData" x-show="$store.ip.isOpen" style="display: none;" x-ref="box" x-init="
    
