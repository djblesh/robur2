    <div class="w-full px-4 flex items-center justify-center gap-4  max-md:flex-col max-md:items-start max-md:gap-2 ">
      <div class="text-sm font-medium text-light " x-html="titleList[location.id || &#39;US&#39;]">You’re viewing the X-SENSE <span class="text-light font-bold">United States (English)</span>. Click here to be redirected to the correct store for your region.</div>
      <div class="flex gap-2 max-md:justify-start max-md:w-full">
