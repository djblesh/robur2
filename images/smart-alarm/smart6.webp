<!-- Google Tag Manager -->
<script>
  const PAGE_RULES = [
    { name: 'Homepage', pattern: /^\/$/ },

    { name: 'Product Listing Page', pattern: /^\/collections(\/.*)?$/ },

    { name: 'Product Detail Page', pattern: /^\/products\/.+$/ },

    { name: 'Search Page', pattern: /^\/search$/ },

    { name: 'Cart Page', pattern: /^\/cart$/ },

    { name: 'Checkout Page', pattern: /^\/checkout\/.+$/ },

    { name: 'Account Page', pattern: /^\/account\/.+$/ },

    { name: 'Blog Page', pattern: /^\/blogs\/tips(\/.*)?$/ },

    { name: 'Contact-us Page', pattern: /^\/pages\/support$/ },

    { name: 'Shipping Policy Page', pattern: /^\/pages\/shipping-policy$/ },

    { name: 'Returns and Warranty Page', pattern: /^\/pages\/returns-and-warranty$/ },

    { name: 'Order Tracking Page', pattern: /^\/pages\/order-tracking$/ },

    { name: 'About Us Page', pattern: /^\/pages\/about-us$/ },

    { name: 'Protect-Premium Page', pattern: /^\/pages\/protect-premium$/ },

    { name: 'Affiliate Page', pattern: /^\/pages\/affiliate$/ },

    { name: 'Partnerships Page', pattern: /^\/pages\/partnerships$/ },
  ];
  function getPageType(pathname) {
      for (const rule of PAGE_RULES) {
        if (rule.pattern.test(pathname)) {
          return rule.name;
        }
      }
      return undefined;
   }
   const pageType = getPageType(window.location.pathname);
   const customerInfo = {
      
        email: undefined,
        phone: undefined,
        id: undefined,
        first_name: undefined,
        last_name: undefined
      
    };
    const loginStatus = customerInfo.id ? 'logged_in' : 'logged_out';
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
        user_id:customerInfo.id,
        login_status:loginStatus,
        content_group:pageType,
    });
</script>

