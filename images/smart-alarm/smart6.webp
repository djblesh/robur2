    <div id="shopify-block-AMXJZdDcwMGd6TkhtQ__footer-pollcy" class="shopify-block">
<style>
  .footer-policy ul li {
    position: relative;
  }
  .footer-policy ul li:not(:last-child)::after {
    content: '';
    position: absolute;
    right: -0.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 0.96875rem;
    background-color: rgba(255, 255, 255, 0.1);
  }
</style>
<div class="mt-4 footer-policy">
  <ul class="flex gap-4 max-md:flex-wrap">
    
      <li>
        <a @click="window.dispatchEvent(new CustomEvent(&#39;footer:navigation&#39;, { detail: { $navigationName1: `Privacy &amp; Terms`, $navigationName2: `Shipping Policy` }}));" href="https://www.x-sense.com/pages/shipping-policy" class="text-light/50 text-sm leading-5 whitespace-nowrap hover:text-light transition-all duration-300">
          Shipping Policy
        </a>
      </li>
    
      <li>
        <a @click="window.dispatchEvent(new CustomEvent(&#39;footer:navigation&#39;, { detail: { $navigationName1: `Privacy &amp; Terms`, $navigationName2: `Returns &amp; Refunds Policy` }}));" href="https://www.x-sense.com/pages/returns-and-warranty" class="text-light/50 text-sm leading-5 whitespace-nowrap hover:text-light transition-all duration-300">
          Returns &amp; Refunds Policy
        </a>
      </li>
    
      <li>
        <a @click="window.dispatchEvent(new CustomEvent(&#39;footer:navigation&#39;, { detail: { $navigationName1: `Privacy &amp; Terms`, $navigationName2: `Warranty Policy` }}));" href="https://www.x-sense.com/pages/warranty-policy" class="text-light/50 text-sm leading-5 whitespace-nowrap hover:text-light transition-all duration-300">
          Warranty Policy
        </a>
