<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('ipData', () => ({
      location: '',
      titleList: {
        US: `You’re viewing the X-SENSE <span class='text-light font-bold'>${Alpine.store(
          'header'
        ).getLocationName()}</span>. Click here to be redirected to the correct store for your region.`,
        FR: `Vous consultez la boutique X-SENSE <span class='text-light font-bold'>${Alpine.store(
          'header'
        ).getLocationName()}</span> Cliquez ici pour être redirigé vers la boutique correspondant à votre région.`,
        DE: `Sie sehen den <span class='text-light font-bold'>X-SENSE Shop für die ${Alpine.store(
          'header'
        ).getLocationName()}</span> Klicken Sie hier, um zum richtigen Shop für Ihre Region weitergeleitet zu werden.`,
        EU: `You’re viewing the X-SENSE <span class='text-light font-bold'>${Alpine.store(
          'header'
        ).getLocationName()}</span>. Click here to be redirected to the correct store for your region.`,
      },
      close() {
        const time = new Date().getTime();
        Alpine.store('ip').isOpen = false;
        localStorage.setItem('IpPopupTime', time);
      },
      getLocation(id) {
        return Alpine.store('header')?.locationList.find((item) => item.id === id);
      },
      async getIp() {
        const oneDay = Number(
          '86400000'
        );
        const lastTime = localStorage.getItem('IpPopupTime') ?? 0;

        if (lastTime && new Date().getTime() < Number(lastTime) + oneDay) {
          Alpine.store('ip').isOpen = false;
          return;
        }

        try {
          const data = await Alpine.store('public').get('/api/ip');
          const currentLocation = Alpine.store('header').getLocationName();
          const isEU = data.isEU ? 'EU' : null;
          if (
            Alpine.store('header').getLocationCurrent() === data.country ||
            Alpine.store('header').getLocationCurrent() === isEU
          )
            return;
          const locationMap = {
            FR: 'FR',
            DE: 'DE',
            US: 'US',
          };
          const matchedLocation = locationMap[data.country] || (data.isEU ? 'EU' : null);
          if (matchedLocation) {
            this.location = this.getLocation(matchedLocation);
            Alpine.store('ip').isOpen = true;
          }
        } catch (e) {
          Alpine.store('ip').isOpen = false;
        } finally {
          localStorage.setItem('IpPopupTime', Date.now());
        }
      },
    }));
    Alpine.store('ip', {
      isOpen: false,
      box: null,
    });
  });
</script>

