      <path class=" group-hover:fill-light transition-all duration-300" fill-rule="evenodd" clip-rule="evenodd" d="M12.8485 5.51533C13.3172 5.0467 13.3172 4.2869 12.8485 3.81827C12.3799 3.34964 11.6201 3.34964 11.1515 3.81827L8.33334 6.63641L5.5152 3.81827C5.04657 3.34964 4.28678 3.34964 3.81815 3.81827C3.34952 4.2869 3.34952 5.0467 3.81815 5.51533L6.63629 8.33346L3.81815 11.1516C3.34952 11.6202 3.34952 12.38 3.81815 12.8487C4.28678 13.3173 5.04657 13.3173 5.5152 12.8487L8.33334 10.0305L11.1515 12.8487C11.6201 13.3173 12.3799 13.3173 12.8485 12.8487C13.3172 12.38 13.3172 11.6202 12.8485 11.1516L10.0304 8.33346L12.8485 5.51533Z" fill="white"></path>
