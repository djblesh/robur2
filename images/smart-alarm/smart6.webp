<script>
  /*
   , el:document.querySelector('#desc')||document.querySelector('#Overview') || null},
 , el:document.querySelector('#Social-Media')||null},
 , el:document.querySelector('#spec')||document.querySelector('#Specification') || null},
 , el:document.querySelector('#faq') || null},
 , el:document.querySelector('#Reviews')||null}
  */
  function navTabs() {
    return {
      embla: null,
      tabs: [
        {
          label: 'Overview',
          el: document.querySelector('#desc') || document.querySelector('#Overview') || null,
        },
        { label: 'Social Media', el: document.querySelector('#Social-Media') || null },
        {
          label: 'Specification',
          el: document.querySelector('#spec') || document.querySelector('#Specification') || null,
        },
        { label: 'FAQ', el: document.querySelector('#faq') || null },
        { label: 'Reviews', el: document.querySelector('#Reviews') || null },
      ],
      activeTab: 0,
      canScrollLeft: false,
      canScrollRight: false,
      isClickScrolling: false,
      isNavFixed: false,
      initEmbla() {
        // 初始化 Embla Carousel
        // dragFree: true 允许自由滑动，像原生 CSS scroll-snap
        // containScroll: 'trimSnaps' 防止边缘空白
        // align: 'center' 确保选中项居中
        this.embla = EmblaCarousel(this.$refs.emblaNode, {
          loop: false,
          align: 'center',
          containScroll: 'trimSnaps',
          dragFree: true,
        });

        // 监听 Embla 事件更新箭头状态
        const updateArrows = () => {
          this.canScrollLeft = this.embla.canScrollPrev();
          this.canScrollRight = this.embla.canScrollNext();
        };

        this.embla.on('select', updateArrows);
        this.embla.on('init', updateArrows);
        this.embla.on('reInit', updateArrows);
        this.embla.on('scroll', updateArrows); // 实时更新

        // 启动 Scroll Spy
        this.initScrollSpy();
      },

      // ---- 点击导航 ----
      scrollToSection(index) {
        this.isClickScrolling = true;
        this.activeTab = index;

        // 1. 让 Embla 滚动到对应 Tab (UI)
        this.embla.scrollTo(index);

        // 2. 页面滚动到对应 ID (Content)
        const targetEl = this.tabs[index].el;
        if (targetEl) {
          //对应的区域再加120
          const offset = 120;
          const scrollPos = targetEl.offsetTop - offset;
          window.scrollTo({ top: scrollPos, behavior: 'smooth' });
        }
        // 延迟解锁 Scroll Spy，防止页面滚动过程中触发其他 Tab 激活
        setTimeout(() => {
          this.isClickScrolling = false;
        }, 1000);
      },

      // ---- Scroll Spy (监听页面滚动联动 Tabs) ----
      initScrollSpy() {
        const onScroll = () => {
          if (this.isClickScrolling) return;
          this.handleNavFixed();
          const offset = 180; // 头部偏移量
          const scrollPos = window.scrollY + offset;

          // 寻找当前激活的 Section
          let newActiveIndex = -1;

          // 倒序查找，确保能够匹配到底部的元素
          for (let i = 0; i < this.tabs.length; i++) {
            const el = this.tabs[i].el;
            if (el) {
              if (scrollPos >= el.offsetTop && scrollPos < el.offsetTop + el.offsetHeight) {
                newActiveIndex = i;
                break;
              }
            }
          }

          // 如果找到了新的激活项，且与当前不同
          if (newActiveIndex !== -1 && newActiveIndex !== this.activeTab) {
            this.activeTab = newActiveIndex;
            // 让 Tab 栏自动滚动到激活项
            this.embla.scrollTo(newActiveIndex);
          }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        // 初始化执行一次
        onScroll();
      },
      handleNavFixed() {
        const mobile = window.innerWidth < 768;
        const nav = this.$el.closest('.product-nav-section');
        const productBox = document.querySelector('.product-main-section');
        const ipHeight = Alpine.store('ip').box?.offsetHeight ?? 0;
        this.isNavFixed = productBox.offsetHeight <= window.scrollY;
        Alpine.store('product').isNavFixed = this.isNavFixed;
        nav.style.top = Alpine.store('header').navHeight + ipHeight - 4 + 'px';
      },
    };
  }
</script>

