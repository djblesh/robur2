      <!-- 内容区 -->
      <div x-init="" style="display: flex" class="h-full max-md:w-full max-md:flex-col max-md:overflow-y-auto min-h-0   scrollbar-custom">
        
        <div x-init="
            const target =$el;
            const waitCartReady = async () =&gt; {
              while ($store.cart.isLoading) {
                await new Promise((r) =&gt; setTimeout(r, 16));
              }
            };
            const observer = new IntersectionObserver((entries) =&gt; {
              entries.forEach(entry =&gt; {
                if (entry.isIntersecting) {
                  (async () =&gt; {
                    await waitCartReady();
                    window.dispatchEvent(new CustomEvent(&#39;cart:nav_view_cart&#39;, { detail: {
                     $value: `${$store.cart.data.total_price/100}`,
                     $coupon: $store.cart.data.discount_codes.map(item =&gt; item?.code).join(&#39;,&#39;),
                     $items: $store.cart.data.items.map((item, index) =&gt; ({
                         $itemId: item.variant_id,
                          $itemName: item.product_title,
                         $coupon: item.discounts.map(item =&gt; item?.code).join(&#39;,&#39;),
                         $discount: `${(item.original_line_price-item.final_line_price)/100/item.quantity}`,
                         $index: index+1,
                         $item_variant: item.variant_title,
                         $item_brand: item.vendor,
                         $price: `${item.price/100}`,
                         $quantity: item.quantity,
                         $currency: &#39;USD&#39;,
                     })),
                 }}));
                  })();
                  
                }
              });
            }, {
              threshold: 0.5 // 50% 可见才触发
            });

            observer.observe(target);
