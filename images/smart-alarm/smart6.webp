<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('productBottom', () => ({
      isInit: true,
      toFixed(price, quantity) {
        const priceValue = +price;
        const quantityValue = +quantity;
        return Math.round((priceValue * quantityValue + Number.EPSILON) * 100) / 100 || undefined;
      },
      handleAddCart() {
        if (
          this.currentVariant.inventory_quantity <= 0 &&
          this.currentVariant.inventory_policy != 'continue'
        ) {
          return;
        }
        const id = this.currentVariant?.id;
        const quantity = this.num;
        const discountCode = this.currentVariant?.discount_code;
        const value = this.currentVariant.price
          .replace('$', '')
          .replace(',', '.');
        Alpine.store('cart').add([{ id, quantity }], discountCode);
        window.dispatchEvent(
          new CustomEvent('product:add_to_cart', {
            detail: {
              $currency: `USD`,
              $value: this.toFixed(value, quantity),
              $buttonName: 'add_to_cart',
              $items: [
                {
                  $itemId: this.currentVariant.id,
                  $itemName: `XS01-M Interconnected Smart Smoke Alarm`,
                  $discount: this.currentVariant.difference,
                  $coupon: this.currentVariant?.discount_code,
                  $index: undefined,
                  $item_variant: this.currentVariant.title,
                  $item_brand: `X-Sense EN`,
                  $price: this.currentVariant.price,
                  $quantity: quantity,
                  $currency: `USD`,
                },
              ],
            },
          })
        );
      },
    }));
  });
</script>

</div>

