<script>
  document.addEventListener('alpine:init', () => {
    const localeMap = {
      US: 'en-US',
      EU: 'en-GB',
      DE: 'de-DE',
      FR: 'fr-FR',
    };

    function formatMoney(
      cents,
      {
        locale = Shopify?.locale || 'en-US',
        currency = Shopify?.currency?.active || 'USD',
        minimumFractionDigits = 2,
        maximumFractionDigits = 2,
      } = {}
    ) {
      if (cents == null || isNaN(cents)) return '';
      const finalLocale = localeMap[currency] || locale;

      let formatted = new Intl.NumberFormat(finalLocale, {
        style: 'currency',
        currency,
        minimumFractionDigits,
        maximumFractionDigits,
      }).format(cents / 100);

      if (currency === 'EUR' && ['de-DE', 'fr-FR'].includes(finalLocale)) {
        formatted = formatted.replace(/\s?€/, '');
        formatted = `${formatted.trim()} €`;
      }

      return formatted;
    }

    Alpine.directive('price', (el, { expression }, { evaluateLater, effect }) => {
      let getValue = evaluateLater(expression);
      effect(() => {
        getValue((cents) => {
          el.textContent = formatMoney(cents);
        });
      });
    });
  });
</script>
<script>
  document.addEventListener('alpine:init', () => {
    Alpine.store('public', {
      api: window.location.hostname.includes('x-sense.com')
        ? 'https://sapi.x-sense.com'
        : 'http://www.xsesetest.beauty',
      Loading: false,
      async get(path, params) {
        this.Loading = true;
        const url = new URL(this.api + path);
        if (params) {
          url.search = new URLSearchParams(params).toString();
        }
        const res = await fetch(url, {
          method: 'GET',
          headers: {
            'Content-Type': 'application/json',
            'X-Site': Alpine.store('header').getLocationCurrent(),
            ...(window.location.hostname.includes('x-sense.com')
              ? {}
              : { 'ngrok-skip-browser-warning': '1' }),
          },
        });
        try {
          const data = await res.json();
          return data;
        } catch (error) {
          console.error(error);
          return {
            success: false,
            code: error.code,
            message: error.message,
          };
        } finally {
          this.Loading = false;
        }
      },
      async post(path, data) {
        this.Loading = true;
        const url = new URL(this.api + path);
        const res = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Site': Alpine.store('header').getLocationCurrent(),
            ...(window.location.hostname.includes('x-sense.com')
              ? {}
              : { 'ngrok-skip-browser-warning': '1' }),
          },
          body: JSON.stringify(data),
        });
        try {
          const data = await res.json();
          return data;
        } catch (error) {
          console.error(error);
          return {
            success: false,
            code: error.code,
            message: error.message,
          };
        } finally {
          this.Loading = false;
        }
      },
      /** 上传文件：传入 FormData，不设置 Content-Type，由浏览器自动带 boundary */
      async upload(path, formData) {
        this.Loading = true;
        const url = new URL(this.api + path);
        const headers = {
          'X-Site': Alpine.store('header').getLocationCurrent(),
          ...(window.location.hostname.includes('x-sense.com')
            ? {}
            : { 'ngrok-skip-browser-warning': '1' }),
        };
        const res = await fetch(url, {
          method: 'POST',
          headers,
          body: formData,
        });
        try {
          const data = await res.json();
          return data;
        } catch (error) {
          console.error(error);
          return {
            success: false,
            code: error.code,
            message: error.message,
          };
        } finally {
          this.Loading = false;
        }
      },
    });
  });
</script>

