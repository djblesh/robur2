<script>
    
    // 加购
    window.addEventListener('cart:add_to_cart', (event) => {
        const { $value, $buttonName, $moduleName, $items } = event.detail;
        window.dataLayer.push({ event_parameters: null });
        window.dataLayer.push({
            event: 'ga4Event',
            event_name: 'add_to_cart',
            event_parameters: {
                currency: `USD` || undefined,
                value: $value? +$value?.replace('$', '').replace(',', '.') : undefined,
                button_name: $buttonName || undefined,
                module_name: $moduleName || undefined,
                items: getProductItems($items).map(i => ({ ...i, location_id: `US` })),
            },
        });
    });
    // 移除购物车
    window.addEventListener('cart:remove_from_cart', (event) => {
        const { $value, $buttonName, $moduleName, $items } = event.detail;
        window.dataLayer.push({ event_parameters: null });
        window.dataLayer.push({
            event: 'ga4Event',
            event_name: 'remove_from_cart',
            event_parameters: {
                currency: `USD` || undefined,
                value:$value? +$value?.replace('$', '').replace(',', '.') : undefined,
                button_name: $buttonName || undefined,
                module_name: $moduleName || undefined,
                items: getProductItems($items).map(i => ({ ...i, location_id: `US` })),
            },
        });
    });
    // 添加优惠券
    window.addEventListener('cart:add_coupon', (event) => {
        const { $coupon, $moduleName } = event.detail;
        window.dataLayer.push({ event_parameters: null });
        window.dataLayer.push({
            event: 'ga4Event',
            event_name: 'add_coupon',
            event_parameters: {
                coupon: $coupon || undefined,
                module_name: $moduleName || undefined,
            },
        });
    });
    // 结算
    window.addEventListener('cart:checkout', (event) => {
        const { $buttonName, $moduleName } = event.detail;
        window.dataLayer.push({ event_parameters: null });
        window.dataLayer.push({
            event: 'ga4Event',
            event_name: 'checkout',
            event_parameters: {
                button_name: $buttonName || undefined,
                module_name: $moduleName || undefined,
            },
        });
    });
    //推荐商品曝光
    window.addEventListener('cart:recommend_view_item_list', (event) => {
        const { $itemListName, $itemListId, $moduleName, $items } = event.detail;
        window.dataLayer.push({ event_parameters: null });
        window.dataLayer.push({
            event: 'ga4Event',
            event_name: 'view_item_list',
            event_parameters: {
                currency: `USD` || undefined,
                item_list_name: 'You may also like' || undefined,
                item_list_id: $itemListId || undefined,
                module_name: 'pop-up cart',
                items: getProductItems($items),
            },
        });
    });
    // 推荐商品点击
    window.addEventListener('cart:recommend_select_item', (event) => {
        const { $itemListName, $itemListId, $buttonName, $moduleName, $items } = event.detail;
        window.dataLayer.push({ event_parameters: null });
        window.dataLayer.push({
            event: 'ga4Event',
            event_name: 'select_item',
            event_parameters: {
                item_list_name: $itemListName || undefined,
                item_list_id: $itemListId || undefined,
                button_name: $buttonName || undefined,
                module_name: "pop-up cart",
                items: getProductItems($items).map(i => ({ ...i, location_id: `US` })),
            },
        });
    });
    // 推荐商品添加到购物车
    window.addEventListener('cart:recommend_add_to_cart', (event) => {
        const { $value, $buttonName, $moduleName, $items } = event.detail;
        window.dataLayer.push({ event_parameters: null });
        window.dataLayer.push({
            event: 'ga4Event',
            event_name: 'add_to_cart',
            event_parameters: {
                currency: `USD` || undefined,
                value: +$value?.replace('$', '').replace(',', '.') || undefined,
                button_name: 'recommend_add_to_cart',
                module_name: "pop-up cart",
                items: getAddToCartItems($items),
            },
        });
    });
    // 正常购物车列表曝光
    window.addEventListener('cart:nav_view_cart', (event) => {
        const { $value, $coupon, $buttonName, $moduleName, $items } = event.detail;
        window.dataLayer.push({ event_parameters: null });
        window.dataLayer.push({
            event: 'ga4Event',
            event_name: 'view_cart',
            event_parameters: {
                currency: `USD` || undefined,
                value: +$value?.replace('$', '').replace(',', '.') || undefined,
                coupon: $coupon || undefined,
                button_name: $buttonName || undefined,
                module_name: 'pop-up cart',
                items: getAddToCartItems($items).map(i => ({ ...i, affillation: undefined, location_id: `US` })),
            },
        });
    });
</script>


    <script>
  //产品浏览
  (() => {
   
    const $items = [
      {
        $itemId: `43710782832880`,
        $itemName: `XS01-M Interconnected Smart Smoke Alarm`,
        coupon: ``,
        $discount: `$26.00`,
        $index: undefined,
        $item_variant: `3*Alarm+1*SBS50 Base Station(FS31)`,
        $item_brand: `X-Sense EN`,
        $price: `$83.99`,
        $quantity: 1,
        $currency: `USD`,
      },
    ];
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'view_item',
      event_parameters: {
        currency: 'USD',
        value: +'83.99',
        items: getAddToCartItems($items),
      },
    });
  })();

  // 产品图片切换
  window.addEventListener('product:view_product_photo', (event) => {
    const { $productName, $photoLabel } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'view_product_photo',
      event_parameters: {
        product_name: $productName || undefined,
        photo_index: $photoLabel || undefined,
      },
    });
  });
  // 产品图片/媒体切换
  window.addEventListener('product:view_product_media', (event) => {
    const { $productName, $buttonName } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'view_product_media',
      event_parameters: {
        product_name: $productName || undefined,
        button_name: $buttonName || undefined,
      },
    });
  });
  // 视频开始
  window.addEventListener('product:video_start', (event) => {
    const { $videoTitle, $videoUrl, $videoDuration, $videoPrecent } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'video_start',
      event_parameters: {
        video_title: $videoTitle || undefined,
        video_url: $videoUrl || undefined,
        video_duration: +$videoDuration || undefined,
        video_percent: +$videoPrecent || undefined,
      },
    });
  });
  // 视频进度
  window.addEventListener('product:video_progress', (event) => {
    const { $videoTitle, $videoUrl, $videoDuration, $videoPrecent } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'video_progress',
      event_parameters: {
        video_title: $videoTitle || undefined,
        video_url: $videoUrl || undefined,
        video_duration: +$videoDuration || undefined,
        video_percent: +$videoPrecent || undefined,
      },
    });
  });
  // 视频完成
  window.addEventListener('product:video_complete', (event) => {
    const { $videoTitle, $videoUrl, $videoDuration, $videoPrecent } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'video_complete',
      event_parameters: {
        video_title: $videoTitle || undefined,
        video_url: $videoUrl || undefined,
        video_duration: +$videoDuration || undefined,
        video_percent: +$videoPrecent || undefined,
      },
    });
  });
  // 立即购买
  window.addEventListener('product:checkout', (event) => {
    const { $productName, $buttonName } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'checkout',
      event_parameters: {
        button_name: $buttonName || undefined,
        module_name: 'product details',
        product_name: $productName || undefined,
      },
    });
  });
  // 添加到购物车
  window.addEventListener('product:add_to_cart', (event) => {
    const { $productName, $buttonName, $items, $value } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'add_to_cart',
      event_parameters: {
        currency: 'USD',
        value: $value|| undefined,
        button_name: $buttonName || undefined,
        module_name: 'product details',
        items: getAddToCartItems($items),
      },
    });
  });
  // 产品选择
  window.addEventListener('product:select_item', (event) => {
    const {   $items, $value } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'view_item',
      event_parameters: {
        currency: 'USD',
        value: $value? +$value?.replace('$', '').replace(',', '.') : undefined,
        items: getAddToCartItems($items),
      },
    });
  });
  // PayPal 分期点击
    // window.dataLayer.push({ event_parameters: null });
    // window.dataLayer.push({
    //   event: 'ga4Event',
    //   event_name: 'view_payment_offer',
    //   event_parameters: {
    //     title: $title || undefined,
    //     product_name: $productName || undefined,
    //     button_name: $buttonName || undefined,
    //   },
    // });
 //查看评论
  window.addEventListener('product:view_review', (event) => {
    const { $productName } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'view_review',
      event_parameters: {
        product_name: $productName || undefined,
      },
    });
  });
  // 查看说明书
  window.addEventListener('product:view_manual', (event) => {
    const { $productName, $buttonName } = event.detail;
    window.dataLayer.push({ event_parameters: null });
    window.dataLayer.push({
      event: 'ga4Event',
      event_name: 'view_manual',
      event_parameters: {
        product_name: $productName || undefined,
        button_name: $buttonName || undefined,
      },
    });
  });
</script>

  

