  <div class="mt-3" x-data="{ ppLoaded: false }" x-init="
      $nextTick(() =&gt; {
        const ppEl = $el.querySelector(&#39;[data-pp-message]&#39;);
        if (ppEl) {
          const observer = new MutationObserver((mutations) =&gt; {
            if (ppEl.children.length &gt; 0 || ppEl.innerText.trim()) {
              ppLoaded = true;
              observer.disconnect();
            }
          });
          observer.observe(ppEl, { childList: true, subtree: true, characterData: true });
          // 超时fallback：10秒后如果还没加载，也隐藏骨架屏
          setTimeout(() =&gt; {
            if (!ppLoaded) {
              ppLoaded = true;
              observer.disconnect();
            }
          }, 10000);
        }
      });
    ">
    <div x-show="ppLoaded" data-pp-message="" data-pp-pagetype="product-details" data-pp-style-layout="text" data-pp-style-logo-type="inline" data-pp-style-text-color="black" data-pp-style-text-size="12" :data-pp-amount="currentVariant.price.replace(&#39;$&#39;, &#39;&#39;)" data-pp-placement="product" data-pp-buyercountry="US" data-pp-amount="83.99" style="" data-pp-id="1"><span id="zoid-paypal-message-uid_24d2507912_mte6mdu6mjc"><style nonce="">
                
