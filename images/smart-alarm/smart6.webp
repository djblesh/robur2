              <li class="flex py-6.25 border-b border-black/10 ">
                <p class="flex-1 flex items-center text-sm font-medium text-black/90 leading-5">
                  Operating Frequency
                </p>
                <p class="flex-1 flex items-center text-sm text-black/50 leading-5 pr-5">
                  915 MHz (US) / 868 MHz (EU)
                </p>
              </li>
            
              <li class="flex py-6.25 border-b border-black/10 ">
