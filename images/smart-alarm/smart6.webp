      const $price =item?.$price? +item.$price.replace('$', '').replace(',', '.') : undefined;
      return {
        item_id: `${item?.$itemId}` || undefined,
        item_name: item?.$itemName || undefined,
        coupon: item?.$coupon || undefined,
