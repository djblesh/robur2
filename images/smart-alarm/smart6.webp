ipt type="text/javascript" async="" src="./smart6_files/willdesk-cart.min.js.download"></script><a class="jdgm-random-link jdgm-hidden" href="https://www.x-sense.com/products/fs31-smoke-alarm-kit?variant=43710782832880#" rel="nofollow" style="display: none;">Judge.me</a><style>
.jdgm-rev__icon::after { content: '\e001'; }
.jdgm-rev__icon::after,
.jdgm-rev__buyer-badge {
  display: inline-block;
  color: #ffffff;
  background-color: rgb(51, 51, 51);
}
.jdgm-rev__buyer-badge:before { content: 'Verified'; }

.jdgm-rev-widg__title { visibility: unset; }
.jdgm-rev-widg__summary-text { visibility: unset; }
.jdgm-prev-badge__text { visibility: unset; }

.jdgm-quest__body:before { content: 'Question:'; }
.jdgm-ans__body:before { content: 'Answer:'; }

.jdgm-star { color: #FC510D; }

.jdgm-ask-question-btn,
.jdgm-write-rev-link,
.jdgm-all-reviews-rating-wrapper,
.jdgm-carousel-wrapper a,
.jdgm-rev__prod-link,
.jdgm-all-reviews-text a,
.jdgm-carousel-item__product,
.jdgm-carousel-number-of-reviews,
.jdgm-revs-tab__url { color: rgb(51, 51, 51); }

a.jdgm-write-rev-link {
    color: rgb(51, 51, 51);
    background-color: #ffffff;
}

/* Legacy selectors, to keep old CSS specificities */
.jdgm-preview-badge .jdgm-star { color: #FC510D; }
.jdgm-histogram .jdgm-star { color: #FC510D; }
</style>
