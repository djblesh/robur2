<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('productRight', () => ({
      selectVariant(id) {
        if (this.num === 0) {
          this.num = 1;
        }
        if (this.currentID === id) return;
        this.currentID = id;
        this.currentVariant = this.variants.find((variant) => variant.id === id);
        const url = new URL(window.location.href);
        url.searchParams.set('variant', id);
        history.replaceState({}, '', url);
        Alpine.store('product').currentVariant = this.currentVariant;
        this.handleSelectImage(1000);
        this.handleInputChange({ target: { value: this.num } });
        window.dispatchEvent(
          new CustomEvent('product:select_item', {
            detail: {
              $productName: `XS01-M Interconnected Smart Smoke Alarm`,
              $value: this.currentVariant.price,
              $items: [
                {
                  $itemId: this.currentVariant.id,
                  $itemName: `XS01-M Interconnected Smart Smoke Alarm`,
                  $discount: this.currentVariant.difference,
                  $coupon: this.currentVariant?.discount_code,
                  $index: undefined,
                  $item_variant: this.currentVariant.title,
                  $item_brand: `X-Sense EN`,
                  $price: this.currentVariant.price,
                  $quantity: 1,
                  $currency: `USD`,
                },
              ],
            },
          })
        );
      },
    }));
  });
</script>

</div>

