          <div :class="{&#39;border-light&#39;: isFocus}" @click="isFocus = !isFocus" class="min-w-40 h-full border border-light/10 rounded-full px-2 bg-light cursor-pointer  transition-all duration-300 flex items-center justify-between">
            <div @focusout="isFocus = false" x-text="location.name" class="w-full h-full  p-2 text-sm focus-visible:outline-none active:outline-none cursor-pointer"></div>
            <svg class="w-4 h-4 shrink-0 mr-2" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M7.26293 11.8626C7.65926 12.2949 8.3409 12.2949 8.73723 11.8626L13.7973 6.34247C14.3853 5.70107 13.9303 4.66675 13.0602 4.66675H2.93998C2.06988 4.66675 1.61488 5.70107 2.20283 6.34247L7.26293 11.8626Z" fill="black" fill-opacity="0.9"></path>
