    </svg>
  

      </div>
      <div class="">
        <h2 x-text="title" class="text-2xl font-bold text-black/90 mb-3 "></h2>
        <p x-text="description" class="text-black/50 text-sm "></p>
        <div class="mt-8 flex flex-col  gap-3">
          <button @click="close()" class="cursor-pointer flex-1 bg-red hover:brightness-80   text-light px-5 py-2.5 text-sm rounded-full font-semi-bold transition-all duration-300 shadow-sm    outline-none">
            I Understand
          </button>
          <a href="https://www.x-sense.com/pages/support" class="cursor-pointer flex-1 bg-light border-2 border-black/5 text-black/90 px-5 py-2.5 text-sm rounded-full font-semi-bold hover:border-black/10 hover:bg-black/5 transition-all duration-300 flex items-center justify-center gap-2   outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-headphones w-4 h-4" aria-hidden="true">
              <path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"></path>
            </svg>
            Contact Support
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('alpine:init', function() {
    Alpine.data('mainPopUp', () => ({
      isOpen: false,
      title:"",
      description:"",
      btnList:
      [{
        country: 'CA',
        title: 'Shipping to Canada Is Currently Unavailable',
        description: 'We’re sorry, but shipping to Canada is not available at this time. We appreciate your interest and hope to serve customers in Canada in the future. If you have any questions, please contact our support team.',
      },{
        country: 'GB<|>UK',
        title: 'Shipping to the United Kingdom Is Currently Unavailable',
        description: 'We’re sorry, but shipping to the United Kingdom is not available at this time. We appreciate your interest and hope to serve customers in the UK in the future. If you have any questions, please contact our support team.',
      },],
      close() {this.isOpen = false;},
      async getSite(){
        const oneDay = Number('86400000');
        const time = localStorage.getItem('siteTime');
        if(time && time > Date.now() - oneDay){
          this.isOpen = false;
          return;
        }
        try{
          const data = await Alpine.store('public').get('/api/ip');
          const country = data?.country?.toUpperCase() ?? 'US';
          localStorage.setItem('siteTime', Date.now());
          const item = this.btnList.find(item => item.country.includes(country));
          if(item){
            this.title = item.title;
            this.description = item.description;
            this.isOpen = true;
          }
        }catch(error){
          console.error(error);
          this.isOpen = false;
        }
      }
    }));
  });
</script>

