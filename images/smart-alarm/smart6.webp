        ],
        isShow: false,
        handleShow() {
          this.isShow = false;
          if (this.currentVariant?.rate && this.currentVariant?.discount_code) {
            this.isShow = true;
           }
          const endTime = this.currentVariant?.end_time
            ? new Date(this.currentVariant?.end_time)
            : null;
          if (endTime && endTime < new Date()) {
            this.isShow = false;
          }
        },
        handleCopyCode(){
        if(this.copySuccess) return;
        navigator.clipboard.writeText(this.currentVariant.discount_code).then(()=>{
          Alpine.store('message').success('Code copied!')
          this.copySuccess = true;
          setTimeout(()=>{
            this.copySuccess = false;
          }, 3000);
        }).catch(()=>{
          Alpine.store('message').error('Failed to copy.')
        })
        },
        handleInputChange(e){
          const value = parseInt(e.target.value);
          if (isNaN(value) || value <= 0 && this.currentVariant.inventory_policy != 'continue') {
          Alpine.store('message').warning('The minimum quantity is 1')
          this.num = 1; return;

          }
          if (value > this.currentVariant.inventory_quantity && this.currentVariant.inventory_policy != 'continue') {
           Alpine.store('message').warning('Quantity cannot exceed available stock')
          this.num = this.currentVariant.inventory_quantity; return;

          }
          this.num = value;
        },
        handleSelectImage(time){
          // if(!this.media || !this.currentVariant?.featured_image_id) return;
          // let index = this.media.findIndex(val => val.id == this.currentVariant?.featured_image_id);
          // index>=0 && this.swiper1.slideTo(index, time, false);
          this.swiper1.slideTo(0, time, false);
        },
      }
    ));
    Alpine.store('product',{
        currentVariant: {},
        isNavFixed:false,
    });
    Alpine.data('countdownTimer', () => ({
        days: '00',
        hours: '00',
        minutes: '00',
        seconds: '00',
        formatted: '0d 0h 0m 0s',
        timer: null,
        endTime: null,
        start(endTime) {
          this.endTime = endTime;
          if (this.timer) {
            clearInterval(this.timer);
          }
          this.update();
          this.timer = setInterval(() => this.update(), 1000);
        },
        update() {
          if (!this.endTime) {
            this.days = this.hours = this.minutes = this.seconds = '00';
            this.formatted = '0d 0h 0m 0s';
            return;
          }
          const now = new Date().getTime();
          const end = new Date(this.endTime).getTime();
          if (isNaN(end) || !this.endTime) {
            this.days = this.hours = this.minutes = this.seconds = '00';
            this.formatted = '0d 0h 0m 0s';
            return;
          }
          const diff = end - now;
          
          if (diff <= 0) {
            clearInterval(this.timer);
            this.days = this.hours = this.minutes = this.seconds = '00';
            this.formatted = '0d 0h 0m 0s';
            return;
          }

          const d = Math.floor(diff / (1000 * 60 * 60 * 24));
          const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
          const m = Math.floor((diff / (1000 * 60)) % 60);
          const s = Math.floor((diff / 1000) % 60);

          this.days = String(d).padStart(2, '0');
          this.hours = String(h).padStart(2, '0');
          this.minutes = String(m).padStart(2, '0');
          this.seconds = String(s).padStart(2, '0');
          this.formatted = `${d}d ${h}h ${m}m ${s}s`;
        },
      }));
  });
  document.addEventListener('alpine:init', () => {
    Alpine.directive('canvas-text', (el, { expression }, { evaluateLater, effect }) => {
      const getText = evaluateLater(expression);

      const draw = (text) => {
        if (!text) return;

        const style = window.getComputedStyle(el);

        const fontSize = style.fontSize;
        const fontWeight = style.fontWeight;
        const fontFamily = style.fontFamily;
        const color = style.color;
        const lineHeight = parseFloat(style.lineHeight) || parseFloat(fontSize) * 1.2;

        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');

        // 👇 关键：用真实字体计算宽度
        ctx.font = `${fontWeight} ${fontSize} ${fontFamily}`;
        const textWidth = ctx.measureText(text).width;
        const fontSizePx = parseFloat(fontSize);
        canvas.width = textWidth + 4;
        canvas.height = fontSizePx;

        // 重新设置 font（canvas resize 会重置）
        ctx.font = `${fontWeight} ${fontSize} ${fontFamily}`;
        ctx.fillStyle = color;
        ctx.textBaseline = 'top';

        ctx.fillText(text, 2, 0);

        el.innerHTML = '';
        el.appendChild(canvas);
      };

      effect(() => {
        getText((value) => {
          requestAnimationFrame(() => {
            draw(value);
          });
        });
      });
    });
  });
  document.addEventListener('alpine:init', () => {
    Alpine.directive('m-text', (el, { expression }, { evaluateLater, effect }) => {
      const getEncoded = evaluateLater(expression);

      const render = async (text) => {
         if (!text) return;
       
         if (document.fonts && document.fonts.ready) {
           await document.fonts.ready;
         }
       
         const style = getComputedStyle(el);
       
         const canvas = document.createElement('canvas');
         const ctx = canvas.getContext('2d');
       
         const dpr = window.devicePixelRatio || 1;
       
         const fontSize = parseFloat(style.fontSize);
         const font = `${style.fontWeight} ${fontSize}px ${style.fontFamily}`;
       
         ctx.font = font;
       
         const padding = 0;
       
         const metrics = ctx.measureText(text);
       
         const width = Math.ceil(metrics.width + padding * 2);
         const height = Math.ceil(fontSize * 1.4);
       
         // 🔥 关键：直接用 dpr 放大画布
         canvas.width = width * dpr;
         canvas.height = height * dpr;
       
         // 🔥 关键：不要用 setTransform 做缩放
         // 改成 reset + scale
         ctx.resetTransform();
         ctx.scale(dpr, dpr);
       
         ctx.font = font;
         ctx.fillStyle = style.color || '#000';
         ctx.textBaseline = 'alphabetic';
       
         const x = padding;
         const y = fontSize;
       
         ctx.clearRect(0, 0, width, height);
         ctx.fillText(text, x, y);
       
         el.innerHTML = '';
         el.appendChild(canvas);
      };

      effect(() => {
        getEncoded(async (encoded) => {
          if (!encoded) return;

          try {
            const decoded = atob(encoded);

            const text = decodeURIComponent(
              Array.from(decoded)
                .map((c) => '%' + c.charCodeAt(0).toString(16).padStart(2, '0'))
                .join('')
            );

            // 🔥 防抖 + 等 DOM 稳定
            requestAnimationFrame(() => {
              render(text);
            });
          } catch (e) {
            console.warn('decode failed:', e);
            el.innerHTML = '';
          }
        });
      });
    });
  });
</script>

