            }
          " @click="handleAddCart" x-text="currentVariant?.inventory_quantity &gt; 0 || currentVariant?.inventory_policy == &#39;continue&#39; ? &#39;Add to Cart&#39; : &#39;Out of Stock&#39;" class="w-50 h-13.5 rounded-full text-base leading-5 text-black/90 font-semi-bold relative overflow-hidden transition-all duration-300 max-md:w-full max-md:flex-1 max-md:h-11 border-2 cursor-pointer hover:text-light hover:bg-black/90 border-black/90">Add to Cart</button>
        <button x-data="
            {
              isLoading: false,
              async goToCheckout(){
               if(num &lt;= 0) return;
               if(this.isLoading) return;
               this.isLoading = true;
                try{
                  await this.clearCart();
                  await this.addCart();
                  await new Promise(resolve =&gt; setTimeout(resolve, 1000));
                  window.location.href = &#39;/checkout&#39;;
                }catch(error){
                  console.error(error);
                }finally{
                  this.isLoading = false;
                }
              },
              async clearCart(){
                try{
                 await fetch(&#39;/cart/clear.js&#39;, {
                     method: &#39;POST&#39;,
                     headers: {
                       &#39;Content-Type&#39;: &#39;application/json&#39;,
                       &#39;Accept&#39;: &#39;application/json&#39;
                     }
                   })
                }catch(error){
                  console.error(error);
                }
              },
              async addCart(){
                 try{
                  await fetch(&#39;/cart/add.js&#39;, {
                    method: &#39;POST&#39;,
                    headers: {
                      &#39;Content-Type&#39;: &#39;application/json&#39;,
                      &#39;Accept&#39;: &#39;application/json&#39;
                    },
                    body: JSON.stringify({
                      items: [{ id: currentVariant?.id, quantity: num, discount: currentVariant?.discount_code }]
                    })
                  });
                }catch(error){
                  console.error(error);
                }
              }
            }
          " @click="
            ()=&gt;{
            window.dispatchEvent(new CustomEvent(&#39;product:checkout&#39;, {
              detail: {
                $productName: `XS01-M Interconnected Smart Smoke Alarm`,
                $buttonName: &#39;Buy Now&#39;
              }
            }));
             goToCheckout()
            }
