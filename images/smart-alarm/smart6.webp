        requestAnimationFrame(() =&gt; {
          requestAnimationFrame(() =&gt; {
            drawerVisible = true
          })
        })
      } else {
        drawerVisible = false
      }
    })
    $watch(&#39;$store.cart.data.items&#39;, val =&gt; {
      isCartList = val.length &gt; 0
    })
  " x-show="$store.cart.isOpenCart" x-transition:enter="transition ease-out duration-50" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" @click="$store.cart.isOpenCart = false" class="fixed inset-0 bg-black/50 z-[99999] " style="display: none">
  <div class="flex justify-end size-full cursor-pointer">
